##1. SETUP FOR EXPERIMENT----
#Loading required packages:
library(airway)              # RNA-seq dataset being employed
library(SummarizedExperiment)# data container class used by airway dataset
library(edgeR)               # for normalization + differential expression
library(ggplot2)             # for plotting
library(limma)               # for plotting
##2. LOADING DATA IN FOR INVESTIGATION----
data("airway")
#Taking a look at the object
airway
#extract counts matrix and sample info
counts  <- assay(airway)          # rows = genes, columns = samples
coldata <- colData(airway)        # sample metadata
#checking dimensions and groups
dim(counts)                   # number of genes and samples
head(coldata)                 # sample annotations
table(coldata$dex)            # number of control vs treated samples
#3. DATA EXPLORATION and QUALITY CONTROL----
###investigating library sizes, i.e. total reads per sample----
#rationale: we want to check for large imbalances between samples, which would necessitate normalization to avoid artefactual DE
lib_sizes <- colSums(counts)
lib_sizes
#FIGURE: library sizes barplot
plot_libsizes <- ggplot(
data = data.frame(sample = colnames(counts), lib_sizes = lib_sizes),
aes(x = sample, y = lib_sizes)
) +
geom_bar(stat = "identity") +
theme_bw() +
labs(
title = "Library sizes per sample",
x = "Sample",
y = "Total read counts"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
#saving figure to designated folder
ggsave("figures/library_sizes_plot.png", plot_libsizes, width = 6, height = 4)
###creating boxplots of raw log counts-----
#rationale: we want to check for overall differences in distribution or outlier samples before formal analysis
#log2 counts + 1 to avoid log(0)
log_counts <- log2(counts + 1)
#plot of raw expression distributions
df_long <- data.frame(
value  = as.vector(log_counts),
sample = rep(colnames(counts), each = nrow(counts))
)
plot_gg_rawED <- ggplot(df_long, aes(x = sample, y = value)) +
geom_boxplot() +
theme_bw() +
labs(
title = "Distribution of log2(counts+1) per sample",
x = "Sample",
y = "log2(counts + 1)"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggsave("figures/ggboxplot_rawED.png", plot_gg_rawED, width = 6, height = 4)
##4. FILTER OUT LOWLY EXPRESSED GENES ----
#Rationale: Lowly expressed genes provide little power for detecting DE and inflate multiple testing so they should be removed
#defining groups: dex = "trt" vs "untrt"
group <- coldata$dex
group
#creating DGEList object for edgeR
y <- DGEList(counts = counts, group = group)
#checking to see how many genes before filtering
nrow(y)
#filtering: keep genes with enough counts
keep.exprs<- filterByExpr(y, group = group)
table(keep.exprs)      # TRUE = genes kept, FALSE = filtered out
y <- y[keep.exprs, , keep.lib.sizes = FALSE]
#checking to see how many genes after filtering
nrow(y)
##5. EXPERIMENTAL VARIATION OF NORMALIZATION STRATEGIES----
# I chose to compare:
#(1) TMM normalization
#(2) library-size-only simple scaling (norm.factors = 1)
#(3) UQ method: upper quartile
###1) TMM normalization----
y_TMM <- calcNormFactors(y, method = "TMM")
y_TMM$samples            # contains norm.factors and library sizes
###2) Simple scaling (i.e. no extra normalization beyond library size)----
y_simple <- calcNormFactors(y, method = "none")
y_simple$samples
###3) UQ normalization----
y_UQ <- calcNormFactors(y, method = "upperquartile")
y_UQ$samples
#creating logCPM matrices for later metrics: these would be genes x samples
logcpm_TMM    <- cpm(y_TMM,    log = TRUE)
logcpm_simple <- cpm(y_simple, log = TRUE)
logcpm_UQ <- cpm(y_UQ, log = TRUE)
##FIGURE:distributions after each normalization
#rationale: we want visual assessment of whether normalization successfully aligns expression distributions across samples
##building a helper function to make long data frame from a matrix
#doing this to turn matrix into a long table with columns value (logCPM), sample, and method so ggplot can facet by method
make_longdf <- function(mat, method_name) {
data.frame(
value  = as.vector(mat),
sample = rep(colnames(mat), each = nrow(mat)),
method = method_name
)
}
df_TMM    <- make_longdf(logcpm_TMM,    "TMM")
df_simple <- make_longdf(logcpm_simple, "Simple")
df_UQ <- make_longdf(logcpm_UQ, "UQ")
df_all <- rbind(df_TMM, df_simple, df_UQ)
plot_box_norm <- ggplot(df_all, aes(x = sample, y = value, fill = method)) +
geom_boxplot(outlier.size = 0.5) +
theme_bw() +
labs(
title = "logCPM distributions under three normalization methods",
x = "Sample",
y = "log2 CPM"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
scale_fill_manual(
values = c(
"Simple" = "#999999",
"TMM"    = "#E69F00",
"UQ"     = "#56B4E9"
)
)
ggsave("figures/ggboxplot_normalized.png", plot_box_norm, width = 7, height = 4.5)
##6. DIFFERENTIAL EXPRESSION ----
#using the standard GLM setup used in edgeR and limma RNA-seq workflows for comparing two groups and then following the edgeR GLM-QL pipeline post normalization
#design matrix: ~ group, intercept + treatment effect
design <- model.matrix(~ group)
design
###Pipeline followed:----
#### I. dispersion estimation----
#### II. quasi-likelihood fit----
#### III. test treatment effect (2nd column)----
#### IV. all genes, sorted by FDR----
###1) DE with TMM normalization----
y_TMM <- estimateDisp(y_TMM, design)
fit_TMM <- glmQLFit(y_TMM, design)
qlf_TMM <- glmQLFTest(fit_TMM, coef = 2)
tab_TMM <- topTags(qlf_TMM, n = Inf)$table
###2) DE with simple normalization----
y_simple <- estimateDisp(y_simple, design)
fit_simple <- glmQLFit(y_simple, design)
qlf_simple <- glmQLFTest(fit_simple, coef = 2)
tab_simple <- topTags(qlf_simple, n = Inf)$table
###3) DE with UQ normalization----
y_UQ <- estimateDisp(y_UQ, design)
fit_UQ <- glmQLFit(y_UQ, design)
qlf_UQ <- glmQLFTest(fit_UQ, coef = 2)
tab_UQ <- topTags(qlf_UQ, n = Inf)$table
##checking the number of differentially expressed genes and their overlap:
#how many DE genes do we have at FDR < 0.05?
sign_TMM    <- tab_TMM$FDR < 0.05
sign_simple <- tab_simple$FDR < 0.05
sign_UQ <- tab_UQ$FDR < 0.05
sum(sign_TMM)
sum(sign_simple)
sum(sign_UQ)
#investigating the overlap between them
genes_TMM    <- rownames(tab_TMM)[sign_TMM]
genes_simple <- rownames(tab_simple)[sign_simple]
genes_UQ <- rownames(tab_UQ)[sign_UQ]
length(intersect(genes_TMM, genes_simple))
length(intersect(genes_UQ, genes_simple))
length(intersect(genes_TMM, genes_UQ))
#computing the Jaccard Index
#rationale:
jaccard <- function(a, b) length(intersect(a, b)) / length(union(a, b))
jac_TMM_simple <- jaccard(genes_TMM,  genes_simple)
jac_TMM_UQ     <- jaccard(genes_TMM,  genes_UQ)
jac_simple_UQ  <- jaccard(genes_simple, genes_UQ)
jac_df <- data.frame(
pair    = c("TMM vs Simple", "TMM vs UQ", "Simple vs UQ"),
jaccard = c(jac_TMM_simple, jac_TMM_UQ, jac_simple_UQ)
)
library(ggplot2)
p_jac <- ggplot(jac_df, aes(x = pair, y = jaccard)) +
geom_col() +
ylim(0, 1) +
theme_bw() +
labs(
title = "Jaccard index for DE gene sets (FDR < 0.05)",
x = "Method pair",
y = "Jaccard index"
)
dir.create("figures", showWarnings = FALSE)
ggsave("figures/jaccard_DE_sets.png", p_jac, width = 6, height = 4)
##FIGURE: Venn Diagram depicting the overlap between DE genes through variation in normalization methods
de_matrix <- cbind(
TMM    = sign_TMM,
Simple = sign_simple,
UQ     = sign_UQ
)
colnames(de_matrix) <- c("TMM", "Simple", "UQ")
vennDiagram(
de_matrix,
circle.col = c("skyblue", "orange", "seagreen"),
main = "Overlap of DE genes (FDR < 0.05)"
)
##FIGURE: Comparison of log2 fold-changes
#rationale: to assess how normalization influences the underlying effect size estimates (log2FC)
#building a df of logFCs for genes common to both tables
common_genes_TMMSimple <- intersect(rownames(tab_TMM), rownames(tab_simple))
fc_compare1 <- data.frame(
gene        = common_genes_TMMSimple,
logFC_TMM   = tab_TMM[common_genes_TMMSimple, "logFC"],
logFC_Simple= tab_simple[common_genes_TMMSimple, "logFC"]
)
#flagging genes DE under TMM to highlight them
fc_compare1$DE_TMM <- tab_TMM[common_genes_TMMSimple, "FDR"] < 0.05
p_fc <- ggplot(fc_compare1, aes(x = logFC_TMM, y = logFC_Simple, colour = DE_TMM)) +
geom_point(alpha = 0.5, size = 0.6) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed") +
scale_colour_manual(values = c("FALSE" = "grey60", "TRUE" = "red")) +
theme_bw() +
labs(
title = "Comparison of log2 fold-changes: TMM vs Simple normalization",
x = "log2 FC (TMM)",
y = "log2 FC (Simple)",
colour = "DE under TMM"
)
ggsave("figures/logFC_TMM_vs_Simple.png", p_fc, width = 6, height = 5)
#confirming
y_TMM$samples
y_simple$samples
#looking at TMM and UQ methods now
common_genes_TMMUQ <- intersect(rownames(tab_TMM), rownames(tab_UQ))
fc_compare2 <- data.frame(
gene      = common_genes_TMMUQ,
logFC_TMM = tab_TMM[common_genes_TMMUQ, "logFC"],
logFC_UQ  = tab_UQ[common_genes_TMMUQ, "logFC"]
)
p_fc2 <- ggplot(fc_compare2, aes(x = logFC_TMM, y = logFC_UQ)) +
geom_point(alpha = 0.5, size = 0.6) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed") +
theme_bw() +
labs(
title = "Comparison of log2 fold-changes: TMM vs UQ normalization",
x = "log2 FC (TMM)",
y = "log2 FC (UQ)"
)
ggsave("figures/logFC_TMM_vs_UQ.png", p_fc2, width = 6, height = 5)
#looking at normalization factors to confirm
y_TMM$samples
y_UQ$samples
##FIGURE: MDS plot oon normalized logCPM
#Rationale: to check whether normalization affects the global separation of treatment groups in expression space
#MDS plot on TMM-normalized logCPM
png("figures/MDS_TMM.png", width = 800, height = 600)
plotMDS(
logcpm_TMM,
labels = as.character(group),
col = ifelse(group == "trt", "red", "blue")
)
title(main = "MDS plot of samples (TMM-normalized logCPM)")
dev.off()
#MDS plot of simple-normalization logCPM for comparison
png("figures/MDS_Simple.png", width = 800, height = 600)
plotMDS(
logcpm_simple,
labels = as.character(group),
col = ifelse(group == "trt", "red", "blue")
)
title(main = "MDS plot of samples (simple-normalized logCPM)")
dev.off()
##7. EVALUATION OF PERFORMANCE----
###A. Computational time----
time_TMM <- system.time({
y_TMM <- calcNormFactors(y, method = "TMM")
fit_TMM <- glmQLFit(y_TMM, design)
qlf_TMM <- glmQLFTest(fit_TMM, coef = 2)
})
time_TMM
time_simple <- system.time({
y_UQ <- calcNormFactors(y, method = "none")
fit_simple <- glmQLFit(y_simple, design)
qlf_simple <- glmQLFTest(fit_simple, coef = 2)
})
time_simple
time_UQ <- system.time({
y_UQ <- calcNormFactors(y, method = "upperquartile")
fit_UQ <- glmQLFit(y_UQ, design)
qlf_UQ <- glmQLFTest(fit_UQ, coef = 2)
})
time_UQ
###B. Precision----
#CoV as a proxy to measure precision
#we are using the normalized logCPM from earlier for each pipeline
#building a helper function to compute per-gene CoV within a group
cov_by_group <- function(logcpm_mat, group_factor, grp) {
idx <- which(group_factor == grp)
m   <- rowMeans(logcpm_mat[, idx, drop = FALSE])
s   <- apply(logcpm_mat[, idx, drop = FALSE], 1, sd)
cov <- s / m
cov
}
cov_TMM_untrt <- cov_by_group(logcpm_TMM, group, "untrt")
cov_TMM_trt   <- cov_by_group(logcpm_TMM, group, "trt")
cov_simple_untrt <- cov_by_group(logcpm_simple, group, "untrt")
cov_simple_trt   <- cov_by_group(logcpm_simple, group, "trt")
cov_UQ_untrt  <- cov_by_group(logcpm_UQ,  group, "untrt")
cov_UQ_trt    <- cov_by_group(logcpm_UQ,  group, "trt")
#Summaries => median CoV
median_cov_TMM <- c(untrt = median(cov_TMM_untrt, na.rm = TRUE),
trt   = median(cov_TMM_trt,   na.rm = TRUE))
median_cov_TMM
median_cov_simple <- c(untrt = median(cov_simple_untrt, na.rm = TRUE),
trt   = median(cov_simple_trt,   na.rm = TRUE))
median_cov_simple
median_cov_UQ  <- c(untrt = median(cov_UQ_untrt,  na.rm = TRUE),
trt   = median(cov_UQ_trt,    na.rm = TRUE))
median_cov_UQ
#the idea here is: lower median CoV => higher precision.
###C. Reliability----
#Pearson's correlation (the default setting with cor function) as a proxy reliability metric
#defining a helper function => mean within-group correlation
mean_within_cor <- function(logcpm_mat, group_factor, grp) {
idx <- which(group_factor == grp)
cor_mat <- cor(logcpm_mat[, idx, drop = FALSE])
#computing the mean of off-diagonal entries
mean(cor_mat[upper.tri(cor_mat)], na.rm = TRUE)
}
rel_df <- data.frame(
method = c("TMM", "Simple", "UQ"),
untrt  = c(mean_within_cor(logcpm_TMM,   group, "untrt"),
mean_within_cor(logcpm_simple,group, "untrt"),
mean_within_cor(logcpm_UQ,    group, "untrt")),
trt    = c(mean_within_cor(logcpm_TMM,   group, "trt"),
mean_within_cor(logcpm_simple,group, "trt"),
mean_within_cor(logcpm_UQ,    group, "trt"))
)
rel_df
#the idea here is: high and very similar across methods => sample-level expression patterns are highly consistent and largely unaffected by normalization choice
## FINAL NOTES: for this small and relatively balanced experiment, DE conclusions are robust to the choice among these standard normalization methods! There are many future avenues to take the exploration in.
