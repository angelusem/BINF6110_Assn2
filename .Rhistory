##7. EVALUATION OF PERFORMANCE----
###A. Computational time----
time_TMM <- system.time({
y_TMM <- calcNormFactors(y, method = "TMM")
fit_TMM <- glmQLFit(y_TMM, design)
qlf_TMM <- glmQLFTest(fit_TMM, coef = 2)
})
time_simple <- system.time({
y_UQ <- calcNormFactors(y, method = "none")
fit_simple <- glmQLFit(y_simple, design)
qlf_simple <- glmQLFTest(fit_simple, coef = 2)
})
time_UQ <- system.time({
y_UQ <- calcNormFactors(y, method = "upperquartile")
fit_UQ <- glmQLFit(y_UQ, design)
qlf_UQ <- glmQLFTest(fit_UQ, coef = 2)
})
###B. Precision----
#CoV as a proxy to measure precision
#we are using the normalized logCPM from earlier for each pipeline
#building a helper function to compute per-gene CoV within a group
cov_by_group <- function(logcpm_mat, group_factor, grp) {
idx <- which(group_factor == grp)
m   <- rowMeans(logcpm_mat[, idx, drop = FALSE])
s   <- apply(logcpm_mat[, idx, drop = FALSE], 1, sd)
cov <- s / m
cov
}
cov_TMM_untrt <- cov_by_group(logcpm_TMM, group, "untrt")
cov_TMM_trt   <- cov_by_group(logcpm_TMM, group, "trt")
cov_simple_untrt <- cov_by_group(logcpm_simple, group, "untrt")
cov_simple_trt   <- cov_by_group(logcpm_simple, group, "trt")
cov_UQ_untrt  <- cov_by_group(logcpm_UQ,  group, "untrt")
cov_UQ_trt    <- cov_by_group(logcpm_UQ,  group, "trt")
#Summaries => median CoV
median_cov_TMM <- c(untrt = median(cov_TMM_untrt, na.rm = TRUE),
trt   = median(cov_TMM_trt,   na.rm = TRUE))
median_cov_simple <- c(untrt = median(cov_simple_untrt, na.rm = TRUE),
trt   = median(cov_simple_trt,   na.rm = TRUE))
median_cov_UQ  <- c(untrt = median(cov_UQ_untrt,  na.rm = TRUE),
trt   = median(cov_UQ_trt,    na.rm = TRUE))
#the idea here is: lower median CoV => higher precision.
###C. Reliability----
#Pearson's correlation (the default setting with cor function) as a proxy reliability metric
#defining a helper function => mean within-group correlation
mean_within_cor <- function(logcpm_mat, group_factor, grp) {
idx <- which(group_factor == grp)
cor_mat <- cor(logcpm_mat[, idx, drop = FALSE])
#computing the mean of off-diagonal entries
mean(cor_mat[upper.tri(cor_mat)], na.rm = TRUE)
}
rel_df <- data.frame(
method = c("TMM", "Simple", "UQ"),
untrt  = c(mean_within_cor(logcpm_TMM,   group, "untrt"),
mean_within_cor(logcpm_simple,group, "untrt"),
mean_within_cor(logcpm_UQ,    group, "untrt")),
trt    = c(mean_within_cor(logcpm_TMM,   group, "trt"),
mean_within_cor(logcpm_simple,group, "trt"),
mean_within_cor(logcpm_UQ,    group, "trt"))
)
#the idea here is:
## FINAL NOTES:
plot_box_norm <- ggplot(df_all, aes(x = sample, y = value, fill = method)) +
geom_boxplot(outlier.size = 0.5) +
theme_bw() +
labs(
title = "logCPM distributions under three normalization methods",
x = "Sample",
y = "log2 CPM"
) +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
scale_fill_manual(
values = c(
"Simple" = "#999999",  # grey
"TMM"    = "#E69F00",  # orange
"UQ"     = "#56B4E9"   # sky blue
)
)
ggsave("figures/ggboxplot_normalized.png", plot_box_norm, width = 7, height = 4.5)
time_TMM
time_simple
time_UQ
median_cov_TMM
median_cov_simple
median_cov_UQ
rel_df
sum(sign_TMM)
