gene        = common_genes_TMMSimple,
logFC_TMM   = tab_TMM[common_genes_TMMSimple, "logFC"],
logFC_Simple= tab_simple[common_genes_TMMSimple, "logFC"]
)
#flagging genes DE under TMM to highlight them
fc_compare1$DE_TMM <- tab_TMM[common_genes_TMMSimple, "FDR"] < 0.05
p_fc <- ggplot(fc_compare1, aes(x = logFC_TMM, y = logFC_Simple, colour = DE_TMM)) +
geom_point(alpha = 0.5, size = 0.6) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed") +
scale_colour_manual(values = c("FALSE" = "grey60", "TRUE" = "red")) +
theme_bw() +
labs(
title = "Comparison of log2 fold-changes: TMM vs Simple normalization",
x = "log2 FC (TMM)",
y = "log2 FC (Simple)",
colour = "DE under TMM"
)
ggsave("figures/logFC_TMM_vs_Simple.png", p_fc, width = 6, height = 5)
#confirming
y_TMM$samples
y_simple$samples
#looking at TMM and UQ methods now
common_genes_TMMUQ <- intersect(rownames(tab_TMM), rownames(tab_UQ))
fc_compare2 <- data.frame(
gene      = common_genes_TMMUQ,
logFC_TMM = tab_TMM[common_genes_TMMUQ, "logFC"],
logFC_UQ  = tab_UQ[common_genes_TMMUQ, "logFC"]
)
p_fc2 <- ggplot(fc_compare2, aes(x = logFC_TMM, y = logFC_UQ)) +
geom_point(alpha = 0.5, size = 0.6) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed") +
theme_bw() +
labs(
title = "Comparison of log2 fold-changes: TMM vs UQ normalization",
x = "log2 FC (TMM)",
y = "log2 FC (UQ)"
)
ggsave("figures/logFC_TMM_vs_UQ.png", p_fc2, width = 6, height = 5)
#looking at normalization factors to confirm
y_TMM$samples
y_UQ$samples
##FIGURE: MDS plot oon normalized logCPM
#rationale:
#MDS plot on TMM-normalized logCPM
png("figures/MDS_TMM.png", width = 800, height = 600)
plotMDS(
logcpm_TMM,
labels = as.character(group),
col = ifelse(group == "trt", "red", "blue")
)
title(main = "MDS plot of samples (TMM-normalized logCPM)")
dev.off()
#MDS plot of simple-normalization logCPM for comparison
png("figures/MDS_Simple.png", width = 800, height = 600)
plotMDS(
logcpm_simple,
labels = as.character(group),
col = ifelse(group == "trt", "red", "blue")
)
title(main = "MDS plot of samples (simple-normalized logCPM)")
